# API tests default to in-memory backends for isolated CI execution.
SESSION_STORE_BACKEND=memory
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
LOGIN_RATE_LIMIT_FALLBACK_TO_MEMORY=true

# Keep outbox enabled for tests that assert outbox summary.
OUTBOX_ENABLED=true
OUTBOX_RELAY_ENABLED=false

# Disable external integrations by default in tests.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SENTRY_DSN=
