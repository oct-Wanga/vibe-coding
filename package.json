{
  "name": "vibe-coding",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "npm --workspace @apps/web run dev",
    "dev:api": "npm --workspace @apps/api run dev",
    "dev:all": "concurrently -k -n web,api \"npm run dev:web\" \"npm run dev:api\"",
    "build": "npm --workspace @apps/web run build",
    "start": "npm --workspace @apps/web run start",
    "lint": "npm --workspace @apps/web run lint",
    "lint:fix": "npm --workspace @apps/web run lint:fix",
    "format": "prettier . --check",
    "format:fix": "prettier . --write",
    "test": "npm --workspace @apps/web run test",
    "test:api": "npm --workspace @apps/api run test",
    "test:all": "npm run test -- --run && npm run test:api",
    "test:e2e": "npm --workspace @apps/web run test:e2e",
    "test:e2e:ui": "npm --workspace @apps/web run test:e2e -- --ui",
    "containers:up": "docker compose -f docker-compose.yml -f docker-compose.kafka.yml up -d",
    "containers:down": "docker compose -f docker-compose.yml -f docker-compose.kafka.yml down -v",
    "kafka:up": "docker compose -f docker-compose.kafka.yml up -d",
    "kafka:down": "docker compose -f docker-compose.kafka.yml down -v",
    "kafka:topics": "node scripts/kafka/create-topics.mjs",
    "kafka:produce": "node scripts/kafka/produce-project-events.mjs",
    "kafka:consume": "node scripts/kafka/consume-project-events.mjs",
    "kafka:consume:dlq": "node scripts/kafka/consume-dlq.mjs",
    "kafka:test": "node scripts/kafka/smoke-test.mjs",
    "release": "npx semantic-release",
    "release:dry-run": "npx semantic-release --dry-run"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "kafkajs": "^2.2.4",
    "prettier": "^3.8.0"
  }
}
