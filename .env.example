# Stagehand
STAGEHAND_ENV=LOCAL
STAGEHAND_MODEL=openai/gpt-5
OPENAI_API_KEY=your_openai_api_key

# Optional (Browserbase)
BROWSERBASE_API_KEY=your_browserbase_api_key
BROWSERBASE_PROJECT_ID=your_browserbase_project_id

# Playwright
E2E_BASE_URL=http://localhost:3000

# Outbox + Kafka (FastAPI backend)
OUTBOX_ENABLED=true
OUTBOX_RELAY_ENABLED=true
OUTBOX_RELAY_POLL_INTERVAL_SECONDS=1.0
OUTBOX_RELAY_BATCH_SIZE=100
OUTBOX_RELAY_MAX_ATTEMPTS=10
KAFKA_BOOTSTRAP_SERVERS=localhost:9094
KAFKA_PROJECTS_CREATED_TOPIC=projects.project-created.v1
KAFKA_CLIENT_ID=fastapi-outbox-relay

# Observability + Sentry (FastAPI backend)
API_ACCESS_LOG_ENABLED=true
API_ACCESS_LOG_SLOW_MS=1000
SENTRY_DSN=
SENTRY_ENVIRONMENT=local
SENTRY_RELEASE=api-local
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0
SENTRY_SEND_DEFAULT_PII=false
